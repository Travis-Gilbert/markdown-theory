{
  "name": "@travis-gilbert/markdown-theory",
  "version": "0.2.0",
  "description": "A markdown renderer whose beauty is computed, not themed. MIT.",
  "license": "MIT",
  "author": "Travis Gilbert",
  "homepage": "https://github.com/Travis-Gilbert/markdown-theory#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Travis-Gilbert/markdown-theory.git",
    "directory": "packages/galley"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./tokens": {
        "types": "./dist/tokens/index.d.ts",
        "default": "./dist/tokens/index.js"
      },
      "./css": "./dist/galley.css",
      "./fonts": "./dist/fonts.css",
      "./fixtures/*.css": "./dist/fixtures/*.css",
      "./react": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "./templates": {
        "types": "./dist/templates/index.d.ts",
        "default": "./dist/templates/index.js"
      },
      "./shelf": {
        "types": "./dist/shelf/index.d.ts",
        "default": "./dist/shelf/index.js"
      },
      "./mdx": {
        "types": "./dist/mdx/index.d.ts",
        "default": "./dist/mdx/index.js"
      }
    }
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    },
    "./css": "./src/css/galley.css",
    "./fonts": "./src/css/fonts.css",
    "./fixtures/*.css": "./fixtures/css/*.css",
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./templates": {
      "types": "./src/templates/index.ts",
      "default": "./src/templates/index.ts"
    },
    "./shelf": {
      "types": "./src/shelf/index.ts",
      "default": "./src/shelf/index.ts"
    },
    "./mdx": {
      "types": "./src/mdx/index.ts",
      "default": "./src/mdx/index.ts"
    }
  },
  "files": [
    "dist/tokens",
    "dist/react",
    "dist/templates",
    "dist/shelf",
    "dist/mdx",
    "dist/galley.css",
    "dist/fonts.css",
    "dist/fixtures",
    "dist/types-*.d.ts"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "rm -rf dist/tokens dist/react dist/templates dist/shelf dist/mdx dist/galley.css dist/fonts.css dist/fixtures dist/types-*.d.ts && tsup",
    "prepack": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.0",
    "@travis-gilbert/document-types": "workspace:*",
    "@travis-gilbert/markdown-spine": "workspace:*",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "hast-util-to-jsx-runtime": "^2.3.2",
    "katex": "^0.16.11",
    "mdast-util-to-hast": "^13.2.0",
    "shiki": "^1.24.2",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@fontsource/encode-sans-semi-expanded": "^5.2.8",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/vollkorn": "^5.2.10",
    "@types/katex": "^0.16.7",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "keywords": [
    "markdown",
    "renderer",
    "design-tokens",
    "typography",
    "oklch",
    "react",
    "mdast"
  ]
}
