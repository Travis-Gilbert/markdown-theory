{
  "name": "galley",
  "version": "0.0.0",
  "description": "A markdown renderer whose beauty is computed, not themed. MIT.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    },
    "./css": "./src/css/galley.css",
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./templates": {
      "types": "./src/templates/index.ts",
      "default": "./src/templates/index.ts"
    },
    "./shelf": {
      "types": "./src/shelf/index.ts",
      "default": "./src/shelf/index.ts"
    },
    "./mdx": {
      "types": "./src/mdx/index.ts",
      "default": "./src/mdx/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.0",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "hast-util-to-jsx-runtime": "^2.3.2",
    "katex": "^0.16.11",
    "markdown-spine": "workspace:*",
    "mdast-util-to-hast": "^13.2.0",
    "shiki": "^1.24.2",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/katex": "^0.16.7",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "keywords": [
    "markdown",
    "renderer",
    "design-tokens",
    "typography",
    "oklch",
    "react",
    "mdast"
  ]
}
