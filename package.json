{
  "name": "galley-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint:literals": "node scripts/lint-literals.mjs",
    "demo:tokens": "tsx packages/galley/scripts/emit-demo.ts",
    "demo:render": "tsx packages/galley/scripts/emit-render-demo.ts",
    "demo:shelf": "tsx packages/galley/scripts/emit-shelf-demo.ts",
    "demo:permutations": "tsx packages/galley/scripts/emit-permutations.ts",
    "demo:readmes": "tsx packages/galley/scripts/emit-readmes.ts",
    "test:visual": "pnpm demo:permutations && pnpm demo:readmes && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
